#!/usr/bin/env bash
# Redeploy Control4 dimmers integration to prod.
# On startup, syncs everything to match the repo. Then polls git for
# new commits and only re-syncs when something changes.
#
# Usage: ./scripts/redeploy
#
# Paths are hardcoded to the prod server layout.

set -euo pipefail

REPO="/data/misc/homeassistant-control4-dimmers"
Z2M_CONVERTERS="/data/misc/menalto-services/zigbee/zigbee2mqtt/data/external_converters"
Z2M_COMPOSE="/data/misc/menalto-services"
HA_COMPONENTS="/data/misc/homeassistant/config/custom_components"
HA_COMPOSE="/data/misc/homeassistant"

POLL_INTERVAL=10
SELF="$(readlink -f "$0")"

cd "$REPO"

ha_differs() {
    ! diff -rq custom_components/control4_dimmers/ "$HA_COMPONENTS/control4_dimmers/" &>/dev/null
}

z2m_differs() {
    for f in z2m/converters/*; do
        if ! diff -q "$f" "$Z2M_CONVERTERS/$(basename "$f")" &>/dev/null; then
            return 0
        fi
    done
    return 1
}

sync_and_restart() {
    local RESTART_Z2M=false
    local RESTART_HA=false

    if ha_differs; then
        echo "  HA integration files differ — syncing"
        rsync -a --delete custom_components/control4_dimmers/ "$HA_COMPONENTS/control4_dimmers/"
        if ha_differs; then
            echo "  WARNING: HA files still differ after sync!"
            diff -rq custom_components/control4_dimmers/ "$HA_COMPONENTS/control4_dimmers/" || true
        fi
        RESTART_HA=true
    fi

    if z2m_differs; then
        echo "  Z2M converter files differ — syncing"
        rsync -a z2m/converters/ "$Z2M_CONVERTERS/"
        if z2m_differs; then
            echo "  WARNING: Z2M files still differ after sync!"
            for f in z2m/converters/*; do
                diff "$f" "$Z2M_CONVERTERS/$(basename "$f")" || true
            done
        fi
        RESTART_Z2M=true
    fi

    if $RESTART_HA; then
        echo "  Restarting Home Assistant"
        docker compose -f "$HA_COMPOSE/docker-compose.yml" restart homeassistant
    fi

    if $RESTART_Z2M; then
        echo "  Restarting Zigbee2MQTT"
        docker compose -f "$Z2M_COMPOSE/docker-compose.yml" restart zigbee2mqtt
    fi

    if ! $RESTART_HA && ! $RESTART_Z2M; then
        echo "  Everything up to date"
    fi
}

# Initial sync on startup
echo "=== redeploy started at $(git rev-parse --short HEAD) ==="
sync_and_restart
LAST_HEAD="$(git rev-parse HEAD)"
echo "  Waiting for new commits..."

# Poll for new commits
while true; do
    sleep "$POLL_INTERVAL"

    SELF_BEFORE="$(md5sum "$SELF")"
    git pull --ff-only 2>&1 | grep -v "^Already up to date.$" || true
    SELF_AFTER="$(md5sum "$SELF")"

    if [[ "$SELF_BEFORE" != "$SELF_AFTER" ]]; then
        echo "  redeploy script changed — re-executing at $(git rev-parse --short HEAD)"
        exec "$SELF" "$@"
    fi

    # Check if HEAD moved (i.e. git pull fetched new commits)
    CURRENT="$(git rev-parse HEAD)"
    if [[ "$LAST_HEAD" != "$CURRENT" ]]; then
        echo ""
        echo "=== $(date '+%H:%M:%S') New commits detected ($(git rev-parse --short HEAD)) ==="
        sync_and_restart
        LAST_HEAD="$CURRENT"
        echo "  Waiting for new commits..."
    fi
done
