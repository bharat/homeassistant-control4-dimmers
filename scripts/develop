#!/usr/bin/env bash
# Start a Home Assistant development environment with MQTT and simulated devices.
#
# Usage:
#   ./scripts/develop          # Start Mosquitto + simulator + HA
#   ./scripts/develop --no-sim # Start Mosquitto + HA (no simulator)
#   ./scripts/develop --fresh  # Start with freshly paired (undetected) devices
#
# All processes run in the foreground via concurrently and stop together on Ctrl+C.
# HA is available at http://localhost:8123

set -euo pipefail
cd "$(dirname "$0")/.."

SCRIPT_DIR="$(pwd)"
CONFIG_DIR="${SCRIPT_DIR}/config"

export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH:-}"

echo "=== Control4 Dimmers Development Server ==="
echo "Config:  ${CONFIG_DIR}"
echo "Integration: custom_components/control4_dimmers"
echo ""

SIM="--sim"
SIM_ARGS=""
for arg in "$@"; do
    case "$arg" in
        --no-sim) SIM="" ;;
        --fresh)  SIM_ARGS="$SIM_ARGS --fresh" ;;
    esac
done

COMMANDS=(
    "mosquitto -p 1883 -v"
    "hass --config ${CONFIG_DIR} --debug"
)
NAMES="mqtt,hass"
COLORS="blue,magenta"

if [ -n "${SIM}" ]; then
    COMMANDS+=("python3 scripts/simulate_devices.py${SIM_ARGS}")
    NAMES="${NAMES},sim"
    COLORS="${COLORS},green"
fi

concurrently \
    --kill-others \
    --names "${NAMES}" \
    --prefix-colors "${COLORS}" \
    --prefix "[{name}]" \
    "${COMMANDS[@]}"
